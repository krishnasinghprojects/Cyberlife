# ══════════════════════════════════════════════════════════════════════════════
# CYBERLIFE — Environment Configuration Template
# Copy this file and rename to .env, then fill in values for your machine.
# ══════════════════════════════════════════════════════════════════════════════

# ── Identity ──────────────────────────────────────────────────────────────────
NODE_UID=                          # Unique ID: MacMini, MacBookPro, DellG15, etc.
NODE_NAME=                         # Display name on the dashboard
NODE_SHELL=/bin/zsh                # Shell for command execution (/bin/zsh, /bin/bash, powershell.exe)

# ── Hub Config (only for hub machines) ────────────────────────────────────────
# HUB_IP=10.120.0.250
# HUB_PORT=8000
# HEARTBEAT_TIMEOUT_MS=60000
# WATCHDOG_INTERVAL_MS=15000
# CLOUDFLARE_API_TOKEN=your_cf_api_token
# CLOUDFLARE_ACCOUNT_ID=your_cf_account_id
# CLOUDFLARE_ZONE_ID=your_cf_zone_id

# ── Agent Config (only for node agents) ───────────────────────────────────────
# HUB_URL=http://10.120.0.250:8000
# NODE_PORT=3001

# ── Modules ───────────────────────────────────────────────────────────────────
# Comma-separated list of modules to enable on this machine.
# Available: command-executor, system-monitor, inference-engine, docker-manager, ssh-engine
ENABLED_MODULES=command-executor,system-monitor

# ── Timers ────────────────────────────────────────────────────────────────────
METRICS_INTERVAL_MS=5000
HEARTBEAT_INTERVAL_MS=30000

# ── Inference Engine (only if inference-engine is enabled) ────────────────────
# OLLAMA_URL=http://localhost:11434
# OLLAMA_DEFAULT_MODEL=llama3.1:8b
# OLLAMA_MODELS=llama3.1:8b,qwen3:0.6b,gemma3:latest
# OLLAMA_SYSTEM_PROMPT=You are Cyberlife AI, an intelligent assistant.
