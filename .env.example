# ══════════════════════════════════════════════════════════════════════════════
# CYBERLIFE — Environment Configuration Template
# ══════════════════════════════════════════════════════════════════════════════
# Note: You do NOT need to fill this out manually!
# Simply run `npm start` and the Cyberlife Setup Wizard will automatically
# collect your preferences and securely generate your .env file for you.
# 
# This template is provided purely for manual overrides or reference.
# ══════════════════════════════════════════════════════════════════════════════

# ── Core Identity ─────────────────────────────────────────────────────────────
NODE_UID=Node_1234
NODE_NAME="Unnamed Node"
NODE_SHELL=/bin/zsh

# ── Central Hub Config (If this machine is the Hub) ───────────────────────────
HUB_IP=0.0.0.0
HUB_PORT=8000
WATCHDOG_INTERVAL_MS=15000
HEARTBEAT_TIMEOUT_MS=60000

# ── Remote Agent Config (If this machine is an Agent) ─────────────────────────
# HUB_URL=http://192.168.1.100:8000
# NODE_PORT=3001
# HEARTBEAT_INTERVAL_MS=30000

# ── Capabilities / Modules ────────────────────────────────────────────────────
# Available: command-executor, system-monitor, ssh-engine, docker-manager, 
#            inference-engine, cloudflare-tunnel
ENABLED_MODULES=command-executor, system-monitor

METRICS_INTERVAL_MS=5000

# ── Optional: AI Inference (Ollama) ───────────────────────────────────────────
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_DEFAULT_MODEL=llama3.2

# ── Optional: Cloudflare Tunnels ──────────────────────────────────────────────
CLOUDFLARE_API_TOKEN=cfut_your_token_here
CLOUDFLARE_ZONE_ID=your_zone_id_here
CLOUDFLARE_ACCOUNT_ID=your_account_id_here
CLOUDFLARE_DOMAIN=yourdomain.com
